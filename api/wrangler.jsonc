  // "r2_buckets": [
  //   {
  //     "binding": "MY_BUCKET",
  //     "bucket_name": "my-bucket"
  //   }
  // ],
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "quizspark",
      "database_id": "1a70de43-61e4-4e69-abd3-0f6ff824bb0a",
      "migrations_dir": "drizzle",
    },
  ],
