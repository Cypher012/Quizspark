{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "api",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-25",
  "compatibility_flags": ["nodejs_compat"],
  "vars": {
    "BACKEND_URL": "http://localhost:8787",
    "FRONTEND_URL": "http://localhost:3000",
    "NODE_ENV": "development",
  },
  // "kv_namespaces": [
  //   {
